#!/bin/bash

set -euo pipefail

# Enable debug logging
DEBUG=true
LOGFILE="/tmp/kubeconfig_debug.log"

# Ensure log file exists
touch "$LOGFILE"

log() {
    local timestamp
    timestamp=$(date +"%Y-%m-%d %H:%M:%S")
    echo "[$timestamp] [DEBUG] $*" | tee -a "$LOGFILE"
}

error() {
    local timestamp
    timestamp=$(date +"%Y-%m-%d %H:%M:%S")
    echo "[$timestamp] [ERROR] $*" | tee -a "$LOGFILE" >&2
}

# Trap to reset terminal and log exit
trap 'reset; log "Script exited and terminal reset."' EXIT
nodes=(a b c)
node=${nodes[$RANDOM % ${#nodes[@]}]}
log "Randomly selected node: $node"

get_remote_kubeconfig() {
    local store=$1
    local server=$2
    log "Fetching kubeconfig for store $store, server $server"

    local passwd
    if ! passwd=$(op read "op://Sherwin/gdpumx6lgxt2imtyn4mbhyktfe/password"); then
        error "Failed to retrieve password from 1Password"
        exit 2
    fi


    passwd=$(op read "op://Sherwin/gdpumx6lgxt2imtyn4mbhyktfe/password")
    if ! expect -c "
     spawn ssh -o \"PreferredAuthentications password\" -o \"StrictHostKeyChecking no\" admin@${store}-server${server}.stores.sherwin.com k3s kubectl config view --flatten
     expect \"password:\"
     send \"${passwd}\r\"
     interact
    " \
        | grep -v spawn \
        | grep -v admin@$store- \
        | sed "s/127.0.0.1/${storeno}-server${server}.stores.sherwin.com/" \
        | sed "s/default/cluster-$storeno/" > $KUBECONFIG; then
        error "Failed to fetch kubeconfig from remote server"
        exit 3
    fi

    log "Successfully fetched kubeconfig"
}

usage() {
    echo "USAGE: $0 store-number"
    echo "$(basename "$0") store-number"
}

if [[ $# -lt 1 ]]; then
    usage
    error "No store number provided"
    exit 1
fi

storeno=$1
shift
log "Store number provided: $storeno"

tmp="/tmp/kubeconfigs/$storeno"
log "Using temp directory: $tmp"
mkdir -p "$tmp"

n=${NODE:-$node}
log "Using node: $n"

export KUBECONFIG="$tmp/kubeconfig"
log "KUBECONFIG path: $KUBECONFIG"

if [[ ! -f "$KUBECONFIG" ]]; then
    log "Kubeconfig not found, retrieving from remote"
    get_remote_kubeconfig "$storeno" "$n"
else
    log "Kubeconfig already exists, skipping fetch"
fi

# if we were called as something with 'k9s' in the name
if echo $0 | grep -q 'k9s'
then
	log "Launching k9s"
	k9s || {
		error "failed to launch k9s"
	}
else
	log "Opening a new shell with the new KUBECONFIG"
	export KUBECONFIG="$tmp/kubeconfig"
	export PS1="kube $storeno> "
	log "Launching subshell with custom PS1"
	cat <<% > /tmp/kubeconfigs/rcfile
alias k=kubectl
alias kt=kubetail
%
	bash --rcfile /tmp/kubeconfigs/rcfile
fi
