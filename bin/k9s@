#!/bin/bash

set -e

tmp=$(mktemp -d)

trap "rm -fr $tmp" EXIT

get_remote_kubeconfig() {
   store=$1; shift
   server=$1; shift
   passwd=$(op read "op://Sherwin/gdpumx6lgxt2imtyn4mbhyktfe/password")
   expect -c "
    spawn ssh admin@$store-server${server}.stores.sherwin.com k3s kubectl config view --flatten
    expect \"password:\"
    send \"$(op read 'op://Sherwin/gdpumx6lgxt2imtyn4mbhyktfe/password')\r\"
    interact
   " \
	| grep -v spawn \
	| grep -v admin@$store- \
   	| sed "s/127.0.0.1/${storeno}-server${server}.stores.sherwin.com/" \
   	| sed "s/default/cluster-$storeno/"
}

usage() {
 echo USAGE $0 store-number
 echo $(basename $0) store-number
} 

storeno=$1
if [[ "x" = "x$storeno" ]]
then
 usage
 exit 1
else
  shift
fi

n=${NODE:-a}
export KUBECONFIG=$tmp/kubeconfig
get_remote_kubeconfig $storeno $n > $KUBECONFIG
exec k9s "$@"
